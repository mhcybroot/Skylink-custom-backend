{
  "manifest_version": 3,
  "name": "Skylink PPW Sync",
  "version": "1.0",
  "description": "Automatically syncs PPW report IDs with the Skylink backend for 1-click access.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://76.13.221.43:8083/*",
    "http://localhost:8083/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skylink Login"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.propertypreswizard.com/*",
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
